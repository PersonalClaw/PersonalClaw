# ─────────────────────────────────────────────────────────────────────────────
# PersonalClaw environment file — copy to `.env` and fill in the values you need.
# `.env` is gitignored; never commit secrets.
#
# All variables are optional unless marked REQUIRED. Sensible defaults apply
# when a variable is unset. Sections with no secrets can be left empty.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Gateway runtime ─────────────────────────────────────────────────────────
# Persistent data directory inside the container (default: /data in Docker,
# ~/.personalclaw on a host install).
# PERSONALCLAW_HOME=/data

# TCP port the dashboard / API listen on.
# PERSONALCLAW_PORT=10000

# TCP bind address. Keep at 127.0.0.1 unless the gateway sits behind a
# trusted reverse proxy or you're running in `none` auth mode (which forces
# loopback regardless).
# When running inside Docker/Finch, set to 0.0.0.0 so port-forwarding works.
# PERSONALCLAW_BIND_HOST=127.0.0.1

# Comma-separated list of additional CORS origins to allow. Loopback origins
# are always allowed.
# PERSONALCLAW_CORS_ORIGINS=

# Image tag pulled by docker-compose.yml (default: latest).
# PERSONALCLAW_IMAGE_TAG=latest


# ─── Authentication ──────────────────────────────────────────────────────────
# Auth mode: local_token (default), api_key, oauth2, or none.
#
#   local_token — JWT printed to container logs at startup. Access by running:
#                 docker exec <container> personalclaw token
#                 The printed URL contains the one-time token.
#
#   api_key     — Static key set via PERSONALCLAW_API_KEY below. Best for Docker
#                 deployments where reading stdout/logs is inconvenient.
#                 Generate a key: openssl rand -hex 32
#
# PERSONALCLAW_AUTH_MODE=local_token

# Static API key used when PERSONALCLAW_AUTH_MODE=api_key. Generate a long random
# string (e.g. `openssl rand -hex 32`). Include as Bearer token or ?api_key=
# query param in requests, or the frontend will prompt for it on first open.
# PERSONALCLAW_API_KEY=


# ─── Slack integration (optional) ────────────────────────────────────────────
# Required only when running the with-slack profile or `personalclaw slack`.
# Get tokens at https://api.slack.com/apps after creating a Socket-Mode app.
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...

# Slack user ID (Uxxxx...) of the operator allowed to interact via Slack.
# Without this set, the Slack handler refuses every message for safety.
# PERSONALCLAW_OWNER_ID=


# ─── LLM provider credentials ────────────────────────────────────────────────
# These names must match the `value_env` fields in your credentials.json
# descriptors. The store reads env first, then inline `value`, then
# ~/.personalclaw/.env.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / OpenAI-compatible endpoints (Together, Groq, DeepSeek, xAI, …).
# Override OPENAI_BASE_URL to point at any compatible endpoint.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# Ollama (local). Override host:port if running on a different machine.
# OLLAMA_HOST=127.0.0.1:11434


# ─── Knowledge / skills marketplace (optional) ───────────────────────────────
# skills.sh API key — CLI fallback runs without it; set this to enable
# direct API access from the dashboard.
# SKILLS_SH_API_KEY=


# ─── Upload limits (optional — sensible defaults) ────────────────────────────
# Per-filetype upload size caps, in BYTES. Defaults: video 2 GiB, audio 1 GiB,
# image 200 MiB, document 100 MiB, archive 500 MiB, other 100 MiB. Files above
# the single-POST threshold stream via the resumable /api/uploads/* protocol
# (progress + resume); at/below it, one multipart POST. Raise a category to allow
# bigger files (also raise nginx client_max_body_size in the /api/uploads/ block
# to match). Examples:
# PERSONALCLAW_UPLOAD_LIMIT_VIDEO=3221225472       # 3 GiB video
# PERSONALCLAW_UPLOAD_LIMIT_IMAGE=524288000        # 500 MiB image
# PERSONALCLAW_UPLOAD_SINGLE_POST_THRESHOLD=52428800  # 50 MiB single-POST cutoff
# Large-audio STT: files over this many bytes are ffmpeg-segmented for transcription.
# PERSONALCLAW_STT_SEGMENT_THRESHOLD=26214400      # 25 MiB


# ─── Dev / advanced (rarely set by hand) ─────────────────────────────────────
# Enable dashboard "dev mode" panels. Truthy values: 1, true, yes.
# PERSONALCLAW_DEV_MODE=

# Disable the auto-nudge feature flag. Set to 0/false/no to turn off.
# PERSONALCLAW_AUTONUDGE=1

# Override the project root the gateway treats as $cwd (overrides auto-detect).
# PERSONALCLAW_PROJECT_DIR=

# Override the workspace name used by the config loader.
# PERSONALCLAW_WORKSPACE=


# ─── Cron / hooks / MCP (set by the gateway, not by users) ───────────────────
# These variables are injected by the gateway into subprocesses (cron jobs,
# MCP servers, hook scripts, ACP agents). They're listed for reference only;
# do NOT set them in `.env` — doing so will confuse the runtime.
#
#   PERSONALCLAW_SESSION_KEY     — propagated to MCP/cron subprocesses
#   PERSONALCLAW_CHANNEL_ID      — Slack channel context for cron + ACP agents
#   PERSONALCLAW_HOOK_EVENT      — set when a lifecycle hook is invoked
#   PERSONALCLAW_HOOK_CONTEXT    — JSON payload for the hook
#   PERSONALCLAW_CLI             — set to "1" inside CLI subprocesses
#   PERSONALCLAW_READY           — startup ready-line marker
#   PERSONALCLAW_TERMINAL        — set inside dashboard PTY children
#   PERSONALCLAW_APP_NAME        — set inside scaffolded app subprocesses
#   PERSONALCLAW_BIN             — resolved path to the personalclaw binary
#   PERSONALCLAW_MCP_JSON        — override path to mcp.json
