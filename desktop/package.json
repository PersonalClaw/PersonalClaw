{
  "name": "personalclaw-electron-mac",
  "version": "0.1.0",
  "description": "PersonalClaw — AI agent desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "dist": "electron-builder --mac --config.electronVersion=$(node -p \"require('electron/package.json').version\")"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.personalclaw.app",
    "productName": "PersonalClaw",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": ["dmg"]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "files": [
      "main.js",
      "context-menu.js",
      "find-bin.js",
      "preload.js",
      "loading.html",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "backend-dist/personalclaw-backend",
        "to": "backend-dist/personalclaw-backend",
        "filter": ["**/*"]
      }
    ]
  }
}
