# Graft the built SPA into the sdist so a wheel built FROM the sdist still carries
# it. `python -m build` (the release + Makefile command) builds the sdist first,
# then builds the wheel from that sdist — setup.py's BuildWithWeb copies web/dist
# into personalclaw/static/dist, but only if web/dist exists in the build tree.
# Without this graft the sdist omits web/dist, so the wheel-from-sdist is SPA-less
# and fails scripts/verify_wheel.py. Grafting it also makes the sdist itself
# self-contained (a wheel built from the PyPI sdist serves the dashboard too).
# web/dist is a gitignored build artifact — run `npm run build` before packaging.
graft web/dist

# Keep the sdist lean: no editor/OS cruft or compiled caches.
global-exclude *.py[cod]
global-exclude .DS_Store
